VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# true sur le site de démo public : connexion anonyme automatique + toutes les fonctions sans abonnement
# (activer aussi Auth > Anonymous dans le dashboard Supabase).
# En démo, les photos Storage vont sous le préfixe demo/ (policies SQL supabase-vehicle-photos-demo-access.sql).
VITE_PUBLIC_DEMO_MODE=false

# Nom du bucket Supabase pour les photos véhicules (doit exister dans Storage avec les policies RLS). Défaut : vehicle-photos
# VITE_VEHICLE_PHOTOS_BUCKET=vehicules-photos

# Si le bucket vehicle-photos est passé en « Public » dans Supabase Storage, mettre true pour l’affichage (sinon URLs signées + policies SELECT).
# VITE_VEHICLE_PHOTOS_IS_PUBLIC=true
